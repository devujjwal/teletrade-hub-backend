# Database Configuration
DB_CONNECTION=mysql
DB_HOST=your_database_host
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password_here
SUPABASE_DATABASE_URL=
SUPABASE_URL=
SUPABASE_SECRET=
SUPABASE_STORAGE_BUCKET_REGISTRATION=registration-documents
SUPABASE_STORAGE_BUCKET_PRODUCTS=product-images
SUPABASE_STORAGE_BUCKET_INVOICES=order-invoices

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=TeleTrade Hub
GOOGLE_APP_EMAIL=
GOOGLE_APP_PASSWORD=
ADMIN_NOTIFICATION_EMAILS=info@telecotrade.com,tctradingek@gmail.com
FRONTEND_URL=http://localhost:3000
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=30

# Application Settings
APP_ENV=production
APP_DEBUG=false

# Vendor API Configuration
VENDOR_API_BASE_URL=https://restful.triel.sk
VENDOR_API_KEY=your_vendor_api_key_here

# Security
ADMIN_TOKEN_EXPIRY=86400

# Pricing
DEFAULT_MARKUP_PERCENTAGE=15.0

# CORS
CORS_ALLOWED_ORIGINS=https://teletrade-hub.vercel.app,http://localhost:3000

# Timezone
TIMEZONE=Europe/Berlin

# Security Keys (NEW - Required for security fixes)
DEBUG_KEY=generate_a_unique_random_64_char_key
SYNC_KEY=generate_a_unique_random_64_char_key

UPS_CLIENT_ID=your_client_id
UPS_CLIENT_SECRET=your_client_secret
UPS_ENVIRONMENT=test

# API cache + frontend ISR revalidation
API_CACHE_ENABLED=true
API_CACHE_DIR=storage/cache/api
API_CACHE_TTL_PRODUCTS=120
API_CACHE_TTL_TAXONOMY=1800
API_CACHE_TTL_TRACKING=60
FRONTEND_REVALIDATE_URL=
FRONTEND_REVALIDATE_SECRET=
CACHE_DIAGNOSTICS_ENABLED=true
